<Window x:Class="LogisticsSystem.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Logistyczny - Inter Cars Integration"
        SizeToContent="Height"
        Width="800"
        Closing="Window_Closing"
        WindowStartupLocation="CenterScreen">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Text="Karta Części Zamiennej" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

		<StackPanel Grid.Row="1" Margin="0,5">
			<TextBlock Text="INFORMACJE O CZĘŚCI" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,10"/>

			<Border Margin="0,0,0,15" Background="#F0F8FF" Padding="10">
				<StackPanel>
					<TextBlock Text="DODAJ NOWY ASORTYMENT" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="Nazwa:" VerticalAlignment="Center" Margin="0,0,5,0"/>
						<TextBox Width="140" Margin="0,0,15,0" Text="{Binding NewPartName, UpdateSourceTrigger=PropertyChanged}"/>

						<TextBlock Text="Kod producenta:" VerticalAlignment="Center" Margin="0,0,5,0"/>
						<TextBox Width="90" Margin="0,0,15,0" Text="{Binding NewPartCode, UpdateSourceTrigger=PropertyChanged}"/>

						<TextBlock Text="Cena (PLN):" VerticalAlignment="Center" Margin="0,0,5,0"/>
						<TextBox Width="60" Margin="0,0,15,0" Text="{Binding NewPartPriceText, UpdateSourceTrigger=PropertyChanged}"/>

						<Button Content="Dodaj do bazy" Padding="15,5" Command="{Binding AddNewPartCommand}" Background="#E1F5FE" BorderBrush="#03A9F4"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<DataGrid x:Name="InventoryGrid"
                      ItemsSource="{Binding PartsInventory}"
                      SelectedItem="{Binding SelectedPart, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Height="150"
                      Margin="0,10"
                      Background="White"
                      AlternatingRowBackground="#F9F9F9">
				<DataGrid.Columns>
					<DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
					<DataGridTextColumn Header="Nazwa części" Binding="{Binding Name}" Width="*"/>
					<DataGridTextColumn Header="Kod producenta" Binding="{Binding ProducerCode}" Width="100"/>
					<DataGridTextColumn Header="Stan" Binding="{Binding StockQuantity}" Width="60"/>
					<DataGridTextColumn Header="Lokalizacja" Binding="{Binding StorageLocation}" Width="150"/>
				</DataGrid.Columns>
			</DataGrid>

			<TextBlock Text="Status zaopatrzenia:" Margin="0,10,0,0"/>
			<StackPanel Orientation="Horizontal" Margin="0,5,0,0" DataContext="{Binding SelectedPart}">
				<TextBlock FontWeight="Bold" VerticalAlignment="Center">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Text" Value="W NORMIE"/>
							<Setter Property="Foreground" Value="DarkGreen"/>
							<Style.Triggers>
								<DataTrigger Binding="{Binding RequiresApproval}" Value="True">
									<Setter Property="Text" Value="ZAMÓWIENIE CZEKA ABY ZATWIERDZIĆ"/>
									<Setter Property="Foreground" Value="Red"/>
								</DataTrigger>
								<DataTrigger Binding="{Binding IsOrderPending}" Value="True">
									<Setter Property="Text" Value="ZAMÓWIENIE W DRODZE"/>
									<Setter Property="Foreground" Value="DarkOrange"/>
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
				<Button Content="Zatwierdź zakup" Margin="15,0,0,0" Padding="10,2" Command="{Binding DataContext.ApproveOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#FFE6E6" BorderBrush="Red">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Visibility" Value="Collapsed"/>
							<Style.Triggers>
								<DataTrigger Binding="{Binding RequiresApproval}" Value="True">
									<Setter Property="Visibility" Value="Visible"/>
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Button.Style>
				</Button>
			</StackPanel>

			<StackPanel Orientation="Horizontal" Margin="0,20,0,0">
				<TextBlock Text="Ilość do przyjęcia:" VerticalAlignment="Center" Margin="0,0,10,0"/>
				<TextBox Width="50" Margin="0,0,10,0" Text="{Binding DeliveryAmountText, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16"/>
				<Button Content="Przyjmij dostawę" Padding="10,5" Command="{Binding ReceiveDeliveryCommand}"/>

				<TextBlock Text="Ilość do wydania:" VerticalAlignment="Center" Margin="30,0,10,0"/>
				<TextBox Width="50" Margin="0,0,10,0" Text="{Binding IssueAmountText, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16"/>
				<Button Content="Wydaj" Padding="10,5" Command="{Binding IssueFromStockCommand}" Background="GhostWhite" />
			</StackPanel>

			<StackPanel Margin="0,20,0,0">
				<TextBlock Text="ZMIANA LOKALIZACJI" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,10"/>
				<StackPanel Orientation="Horizontal">
					<TextBlock Text="Alejka:" VerticalAlignment="Center" Margin="0,0,5,0"/>
					<TextBox Width="40" Margin="0,0,10,0" Text="{Binding AisleInput, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center"/>
					<TextBlock Text="Regał:" VerticalAlignment="Center" Margin="0,0,5,0"/>
					<TextBox Width="40" Margin="0,0,10,0" Text="{Binding RackInput, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center"/>
					<TextBlock Text="Półka:" VerticalAlignment="Center" Margin="0,0,5,0"/>
					<TextBox Width="40" Margin="0,0,15,0" Text="{Binding ShelfInput, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center"/>
					<Button Content="Zmień lokalizację" Padding="10,5" Command="{Binding ChangeLocationCommand}"/>
				</StackPanel>
			</StackPanel>

			<StackPanel Margin="0,20,0,0" DataContext="{Binding SelectedPart}">
				<TextBlock Text="HISTORIA OPERACJI" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,5"/>
				<ListBox ItemsSource="{Binding OperationHistory}"
                         Height="100"
                         Background="#FAFAFA"
                         BorderBrush="#E0E0E0"
                         Padding="5"/>
			</StackPanel>

		</StackPanel>
	</Grid>
</Window>